<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.focusmonitor.client.clientdesktop.controller.HomepageController"
           stylesheets="@style.css"
           styleClass="root">

    <Pane mouseTransparent="true" styleClass="bg-orb bg-orb-one"/>
    <Pane mouseTransparent="true" styleClass="bg-orb bg-orb-two"/>

    <BorderPane maxWidth="1240" maxHeight="700" styleClass="dashboard-shell">
        <top>
            <HBox alignment="CENTER_LEFT" spacing="24" styleClass="dashboard-topbar">
                <VBox spacing="4">
                    <Label text="Focus Monitor" styleClass="topbar-brand"/>
                    <Label text="Desktop focus dashboard" styleClass="topbar-subtitle"/>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="10" HBox.hgrow="ALWAYS">
                    <Button text="Dashboard" styleClass="nav-chip" id="dashboardNavButton"/>
                    <Button text="Settings" styleClass="nav-chip"/>
                    <Button text="Logout" styleClass="nav-chip" id="logoutNavButton" onAction="#logout"/>
                </HBox>
            </HBox>
        </top>

        <left>
            <VBox spacing="18" styleClass="dashboard-sidebar">
                <Label text="Workspace" styleClass="sidebar-title"/>
                <Button text="Overview" styleClass="sidebar-button" id="overviewSidebarButton"/>
                <Button text="Tasks" styleClass="sidebar-button"/>
                <Button text="Reports" styleClass="sidebar-button"/>

                <VBox spacing="10" styleClass="sidebar-note">
                    <Label text="Tracking mode" styleClass="sidebar-note-title"/>
                    <Label text="Keep the monitor running while you work to build cleaner daily summaries." wrapText="true" styleClass="sidebar-note-copy"/>
                </VBox>
            </VBox>
        </left>

        <center>
            <GridPane hgap="20" vgap="20" styleClass="dashboard-grid">
                <columnConstraints>
                    <ColumnConstraints percentWidth="55.0" />
                    <ColumnConstraints percentWidth="45.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints percentHeight="48.0" />
                    <RowConstraints percentHeight="52.0" />
                </rowConstraints>

                <VBox spacing="18" styleClass="dashboard-card" id="heroDashboardCard" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Focus Session Control" styleClass="panel-kicker"/>
                    <Label text="Start tracking the work in front of you." styleClass="panel-title" wrapText="true"/>
                    <Label text="Launch monitoring when you're ready. The desktop client will watch your active window changes and keep the backend session in sync." styleClass="panel-copy" wrapText="true"/>
                    <Button text="Start Monitoring" styleClass="button-primary" id="heroStartButton" prefWidth="220" onAction="#startMonitor"/>
                    <Label text="One click starts a new monitored run." styleClass="muted-copy"/>
                </VBox>

                <VBox spacing="14" styleClass="dashboard-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Live Status" styleClass="panel-kicker"/>
                    <Label fx:id="welcomeLabel" styleClass="panel-title-small" wrapText="true"/>
                    <VBox spacing="8" styleClass="status-block">
                        <Label text="Current window" styleClass="status-label"/>
                        <Label fx:id="activeWindowLabel" text="Active window will appear here" styleClass="status-value" wrapText="true"/>
                    </VBox>
                    <HBox spacing="12">
                        <VBox spacing="4" styleClass="mini-stat">
                            <Label text="State" styleClass="mini-stat-label"/>
                            <Label text="Ready" styleClass="mini-stat-value"/>
                        </VBox>
                        <VBox spacing="4" styleClass="mini-stat">
                            <Label text="Sync" styleClass="mini-stat-label"/>
                            <Label text="Online" styleClass="mini-stat-value"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox spacing="14" styleClass="dashboard-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Recent Activity" styleClass="panel-kicker"/>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Session timeline" styleClass="panel-title-small"/>
                        <Button text="Refresh" styleClass="nav-chip" onAction="#refreshTodaySummary"/>
                    </HBox>
                    <VBox spacing="10">
                        <HBox spacing="12" styleClass="activity-row">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="activityTitle1" text="No sessions yet" styleClass="activity-title"/>
                                <Label fx:id="activityCopy1" text="Start monitoring to collect today's activity." styleClass="activity-copy"/>
                            </VBox>
                            <Label fx:id="activityTime1" text="-" styleClass="activity-time"/>
                        </HBox>
                        <HBox spacing="12" styleClass="activity-row">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="activityTitle2" text="No sessions yet" styleClass="activity-title"/>
                                <Label fx:id="activityCopy2" text="The dashboard will show app windows from DB." styleClass="activity-copy"/>
                            </VBox>
                            <Label fx:id="activityTime2" text="-" styleClass="activity-time"/>
                        </HBox>
                        <HBox spacing="12" styleClass="activity-row">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label fx:id="activityTitle3" text="No sessions yet" styleClass="activity-title"/>
                                <Label fx:id="activityCopy3" text="Data refreshes when dashboard opens." styleClass="activity-copy"/>
                            </VBox>
                            <Label fx:id="activityTime3" text="-" styleClass="activity-time"/>
                        </HBox>
                    </VBox>
                </VBox>

                <VBox spacing="14" styleClass="dashboard-card" id="accentDashboardCard" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Daily Focus" styleClass="panel-kicker" id="accentKicker"/>
                    <Label text="Productivity snapshot" styleClass="panel-title-small" id="accentTitle"/>
                    <Label text="This area is ready for your chart or summary widgets once the backend stats are wired in." styleClass="panel-copy-light" wrapText="true"/>
                    <StackPane styleClass="chart-placeholder">
                        <Label text="Chart placeholder" styleClass="chart-placeholder-text"/>
                    </StackPane>
                </VBox>
            </GridPane>
        </center>

        <bottom>
            <HBox alignment="CENTER_LEFT" styleClass="dashboard-footer">
                <Label text="Focus Monitor desktop workspace" styleClass="footer-copy"/>
            </HBox>
        </bottom>
    </BorderPane>
</StackPane>
